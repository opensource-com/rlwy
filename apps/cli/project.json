{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cli/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/target/release"],
      "options": {
        "command": "cargo build --release",
        "cwd": "apps/cli"
      }
    },
    "build-debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build",
        "cwd": "apps/cli"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --",
        "cwd": "apps/cli"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "apps/cli"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -- -D warnings",
        "cwd": "apps/cli"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt",
        "cwd": "apps/cli"
      }
    }
  }
}
